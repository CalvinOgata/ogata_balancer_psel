# Long-lived shared secret. The 5-minute rotating token is derived from this
# via HMAC-SHA256(secret, current_epoch_index). Generate a fresh value with:
#   openssl rand -hex 32
APP_SECRET_TOKEN=replace_me_with_64_hex_chars

# Public-facing ports on the host
LB_HTTP_PORT=8080
LB_HTTPS_PORT=8443

# Internal docker network ports
LB_INTERNAL_HTTPS_PORT=8443
LB_HEALTH_INGEST_PORT=9443
SERVER_PORT=4443

# How often each server pushes a health report to the load balancer (seconds)
HEALTH_REPORT_INTERVAL_SECS=2
